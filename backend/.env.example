PORT=10000
NODE_ENV=production
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/materpools
JWT_SECRET=your_super_secret_jwt_key_min_32_chars
JWT_EXPIRES_IN=7d
CLIENT_URL=https://masterpools.co.zw

# ImageKit Configuration
IMAGEKIT_PUBLIC_KEY=your_public_key
IMAGEKIT_PRIVATE_KEY=your_private_key
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_endpoint

# Email Configuration (Gmail with App Password)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=noreply@masterpools.co.zw

# Admin Credentials (Change in production!)
ADMIN_EMAIL=admin@masterpools.co.zw
ADMIN_PASSWORD=ChangeMe@2026!

# Resend Email Service
RESEND_API_KEY=your_resend_key
RESEND_FROM=noreply@masterpools.co.zw
